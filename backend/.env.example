# =============================================
# CONFIGURACIÓN DEL SERVIDOR
# En Vercel el PORT lo asigna la plataforma automáticamente
# =============================================
PORT=5000

# =============================================
# BASE DE DATOS - SUPABASE / POSTGRESQL
# Puedes encontrar estos datos en:
# Supabase > Project Settings > Database > Connection string
# =============================================
DATABASE_URL=postgresql://postgres:[TU_PASSWORD]@db.[TU_PROJECT_ID].supabase.co:5432/postgres

# =============================================
# JWT - TOKEN DE AUTENTICACIÓN
# Genera un string aleatorio largo y seguro para usar como secreto
# =============================================
JWT_SECRET=tu_secreto_jwt_muy_seguro_y_largo

# =============================================
# CORREO ELECTRÓNICO - NODEMAILER
# Configura tu cuenta de correo para enviar emails de recuperación
# Si usas Gmail, necesitas activar "Contraseñas de aplicación" en tu cuenta
# =============================================
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=tu_correo@gmail.com
EMAIL_PASS=tu_contraseña_de_aplicacion_gmail

# =============================================
# URL DEL FRONTEND (para CORS)
# En producción usa la URL de Vercel de tu frontend
# Para múltiples orígenes sepáralos con coma:
# FRONTEND_URL=https://motormatch.vercel.app,https://motormatch-git-main.vercel.app
# =============================================
FRONTEND_URL=https://tu-frontend.vercel.app
